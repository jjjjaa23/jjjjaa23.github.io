/* =====================================================
   XIORVE Website V2.1 Premium
   Author: OpenAI
===================================================== */

/* =========================
   CSS VARIABLES
========================= */

:root{

    --primary:#0057ff;
    --primary-dark:#003bb3;
    --secondary:#0f172a;

    --white:#ffffff;
    --light:#f7f9fc;
    --gray:#6b7280;
    --dark:#111827;

    --border:#e5e7eb;

    --shadow-small:0 8px 24px rgba(0,0,0,.05);
    --shadow:0 20px 60px rgba(0,0,0,.08);
    --shadow-large:0 35px 80px rgba(0,0,0,.15);

    --radius:18px;

    --transition:.35s ease;

}

/* =========================
   RESET
========================= */

*{

    margin:0;
    padding:0;
    box-sizing:border-box;

}

html{

    scroll-behavior:smooth;

}

body{

    font-family:"Inter",sans-serif;

    color:var(--dark);

    background:#ffffff;

    overflow-x:hidden;

    line-height:1.7;

}

img{

    display:block;

    width:100%;

}

a{

    text-decoration:none;

    color:inherit;

}

ul{

    list-style:none;

}

.container{

    width:min(1200px,92%);

    margin:auto;

}

/* =========================
   TYPOGRAPHY
========================= */

.section-tag{

    display:inline-block;

    color:var(--primary);

    font-size:14px;

    font-weight:700;

    letter-spacing:2px;

    text-transform:uppercase;

    margin-bottom:18px;

}

.section-header{

    text-align:center;

    max-width:760px;

    margin:0 auto 70px;

}

.section-header h2{

    font-size:48px;

    line-height:1.15;

    margin-bottom:20px;

}

.section-header p{

    color:var(--gray);

    font-size:17px;

}

/* =========================
   BUTTONS
========================= */

.primary-btn{

    display:inline-flex;

    align-items:center;

    justify-content:center;

    padding:16px 36px;

    border-radius:50px;

    background:var(--primary);

    color:#fff;

    font-weight:600;

    transition:var(--transition);

    box-shadow:var(--shadow-small);

}

.primary-btn:hover{

    background:var(--primary-dark);

    transform:translateY(-3px);

}

.secondary-btn{

    display:inline-flex;

    align-items:center;

    justify-content:center;

    padding:16px 36px;

    border-radius:50px;

    border:1px solid var(--border);

    color:var(--dark);

    transition:var(--transition);

}

.secondary-btn:hover{

    background:var(--primary);

    color:#fff;

    border-color:var(--primary);

}

.text-btn{

    display:inline-flex;

    align-items:center;

    gap:10px;

    color:var(--primary);

    font-weight:600;

    transition:var(--transition);

}

.text-btn:hover{

    gap:16px;

}/* =====================================================
   HEADER
===================================================== */

.header{

    position:fixed;

    top:0;

    left:0;

    width:100%;

    z-index:999;

    background:rgba(255,255,255,.92);

    backdrop-filter:blur(18px);

    border-bottom:1px solid rgba(0,0,0,.05);

    transition:.35s;

}

.header .container{

    height:82px;

    display:flex;

    justify-content:space-between;

    align-items:center;

}

.logo img{

    width:180px;

}

.navbar ul{

    display:flex;

    gap:40px;

}

.navbar a{

    font-size:15px;

    font-weight:600;

    color:var(--dark);

    transition:.3s;

    position:relative;

}

.navbar a::after{

    content:"";

    position:absolute;

    left:0;

    bottom:-8px;

    width:0;

    height:2px;

    background:var(--primary);

    transition:.3s;

}

.navbar a:hover{

    color:var(--primary);

}

.navbar a:hover::after{

    width:100%;

}

.quote-btn{

    display:inline-flex;

    align-items:center;

    justify-content:center;

    padding:14px 28px;

    border-radius:50px;

    background:var(--primary);

    color:#fff;

    font-weight:600;

    transition:.35s;

}

.quote-btn:hover{

    background:var(--primary-dark);

    transform:translateY(-3px);

}

.mobile-menu{

    display:none;

    font-size:28px;

    cursor:pointer;

}

/* =====================================================
   HERO
===================================================== */

.hero-section{

    padding-top:150px;

    padding-bottom:120px;

    background:linear-gradient(180deg,#ffffff,#f7faff);

}

.hero-grid{

    display:grid;

    grid-template-columns:1.05fr .95fr;

    gap:80px;

    align-items:center;

}

.hero-tag{

    display:inline-block;

    color:var(--primary);

    font-size:14px;

    letter-spacing:2px;

    font-weight:700;

    margin-bottom:24px;

}

.hero-left h1{

    font-size:68px;

    line-height:1.05;

    font-weight:800;

    margin-bottom:28px;

    color:var(--secondary);

}

.hero-left p{

    font-size:18px;

    color:var(--gray);

    max-width:620px;

    margin-bottom:42px;

}

.hero-buttons{

    display:flex;

    gap:18px;

    flex-wrap:wrap;

}

.hero-right{

    position:relative;

}

.hero-right img{

    border-radius:28px;

    box-shadow:var(--shadow-large);

}

.hero-right::before{

    content:"";

    position:absolute;

    width:320px;

    height:320px;

    background:rgba(0,87,255,.08);

    border-radius:50%;

    top:-40px;

    right:-40px;

    z-index:-1;

}

.hero-right::after{

    content:"";

    position:absolute;

    width:180px;

    height:180px;

    background:rgba(0,87,255,.05);

    border-radius:50%;

    bottom:-30px;

    left:-30px;

    z-index:-1;

}/* =====================================================
   STATISTICS
===================================================== */

.statistics-section{

    padding:90px 0;

    background:#ffffff;

}

.statistics-grid{

    display:grid;

    grid-template-columns:repeat(4,1fr);

    gap:28px;

}

.stat-item{

    background:#ffffff;

    border:1px solid var(--border);

    border-radius:22px;

    padding:42px 30px;

    text-align:center;

    transition:var(--transition);

    box-shadow:var(--shadow-small);

}

.stat-item:hover{

    transform:translateY(-8px);

    box-shadow:var(--shadow);

}

.stat-item h2{

    font-size:44px;

    color:var(--primary);

    margin-bottom:12px;

    font-weight:800;

}

.stat-item p{

    color:var(--gray);

    font-size:15px;

    font-weight:500;

}

/* =====================================================
   ABOUT
===================================================== */

.about-section{

    padding:120px 0;

    background:var(--light);

}

.about-grid{

    display:grid;

    grid-template-columns:1fr 1fr;

    gap:80px;

    align-items:center;

}

.about-image img{

    border-radius:28px;

    box-shadow:var(--shadow-large);

}

.about-content h2{

    font-size:50px;

    line-height:1.15;

    margin-bottom:28px;

}

.about-content p{

    color:var(--gray);

    margin-bottom:24px;

}

.about-list{

    margin:40px 0;

}

.about-item{

    display:flex;

    align-items:center;

    gap:16px;

    margin-bottom:18px;

}

.about-item i{

    color:var(--primary);

    font-size:18px;

}

.about-item span{

    font-weight:500;

}

/* =====================================================
   MANUFACTURING
===================================================== */

.manufacturing-section{

    padding:120px 0;

    background:#ffffff;

}

.manufacturing-grid{

    display:grid;

    grid-template-columns:1fr 1fr;

    gap:80px;

    align-items:center;

}

.manufacturing-content h2{

    font-size:48px;

    line-height:1.15;

    margin:20px 0 28px;

}

.manufacturing-content p{

    color:var(--gray);

    margin-bottom:34px;

}

.manufacturing-list{

    display:grid;

    gap:18px;

}

.manufacturing-item{

    display:flex;

    align-items:center;

    gap:18px;

    padding:18px 20px;

    border-radius:18px;

    background:#f8fbff;

    transition:var(--transition);

}

.manufacturing-item:hover{

    background:#eef5ff;

    transform:translateX(8px);

}

.manufacturing-item i{

    width:46px;

    height:46px;

    display:flex;

    align-items:center;

    justify-content:center;

    border-radius:12px;

    background:var(--primary);

    color:#ffffff;

    font-size:18px;

}

.manufacturing-item span{

    font-weight:600;

}

.manufacturing-image img{

    border-radius:28px;

    box-shadow:var(--shadow-large);

}/* =====================================================
   PRODUCTS
===================================================== */

.products-section{

    padding:120px 0;

    background:#ffffff;

}

.products-grid{

    display:grid;

    grid-template-columns:repeat(2,1fr);

    gap:40px;

}

.product-card{

    background:#ffffff;

    border-radius:28px;

    overflow:hidden;

    border:1px solid var(--border);

    box-shadow:var(--shadow-small);

    transition:var(--transition);

}

.product-card:hover{

    transform:translateY(-10px);

    box-shadow:var(--shadow-large);

}

.product-image{

    overflow:hidden;

}

.product-image img{

    height:340px;

    object-fit:cover;

    transition:.6s;

}

.product-card:hover .product-image img{

    transform:scale(1.08);

}

.product-content{

    padding:36px;

}

.product-type{

    display:inline-block;

    color:var(--primary);

    font-size:13px;

    font-weight:700;

    letter-spacing:2px;

    margin-bottom:14px;

}

.product-content h3{

    font-size:32px;

    margin-bottom:18px;

}

.product-content p{

    color:var(--gray);

    margin-bottom:28px;

}

.product-spec{

    margin-bottom:30px;

}

.product-spec li{

    display:flex;

    align-items:center;

    gap:12px;

    margin-bottom:14px;

}

.product-spec i{

    color:var(--primary);

}

/* =====================================================
   APPLICATIONS
===================================================== */

.applications-section{

    padding:120px 0;

    background:var(--light);

}

.applications-grid{

    display:grid;

    grid-template-columns:repeat(2,1fr);

    gap:32px;

}

.application-card{

    position:relative;

    overflow:hidden;

    border-radius:24px;

    cursor:pointer;

}

.application-card img{

    height:340px;

    object-fit:cover;

    transition:.6s;

}

.application-card:hover img{

    transform:scale(1.1);

}

.application-content{

    position:absolute;

    left:0;

    right:0;

    bottom:0;

    padding:30px;

    background:linear-gradient(

        transparent,

        rgba(0,0,0,.85)

    );

}

.application-content h3{

    color:#fff;

    font-size:28px;

    margin-bottom:10px;

}

.application-content p{

    color:rgba(255,255,255,.82);

}

/* =====================================================
   IMAGE EFFECT
===================================================== */

.product-card img,

.application-card img{

    backface-visibility:hidden;

    will-change:transform;

}/* =====================================================
   WHY XIORVE
===================================================== */

.why-section{

    padding:120px 0;

    background:#ffffff;

}

.why-grid{

    display:grid;

    grid-template-columns:repeat(4,1fr);

    gap:30px;

}

.why-card{

    background:#ffffff;

    border:1px solid var(--border);

    border-radius:24px;

    padding:40px 30px;

    text-align:center;

    transition:var(--transition);

    box-shadow:var(--shadow-small);

}

.why-card:hover{

    transform:translateY(-10px);

    box-shadow:var(--shadow);

}

.why-icon{

    width:78px;

    height:78px;

    margin:auto;

    margin-bottom:24px;

    border-radius:20px;

    background:linear-gradient(135deg,#0057ff,#3d7dff);

    display:flex;

    align-items:center;

    justify-content:center;

}

.why-icon i{

    color:#ffffff;

    font-size:30px;

}

.why-card h3{

    font-size:26px;

    margin-bottom:16px;

}

.why-card p{

    color:var(--gray);

}

/* =====================================================
   CERTIFICATE
===================================================== */

.certificate-section{

    padding:120px 0;

    background:var(--light);

}

.certificate-grid{

    display:grid;

    grid-template-columns:1fr 1fr;

    gap:80px;

    align-items:center;

}

.certificate-left h2{

    font-size:48px;

    margin:20px 0 30px;

    line-height:1.15;

}

.certificate-left p{

    color:var(--gray);

    margin-bottom:35px;

}

.certificate-items{

    display:grid;

    gap:18px;

}

.certificate-item{

    display:flex;

    align-items:center;

    gap:16px;

    background:#ffffff;

    padding:18px 22px;

    border-radius:18px;

    box-shadow:var(--shadow-small);

    transition:var(--transition);

}

.certificate-item:hover{

    transform:translateX(8px);

}

.certificate-item i{

    color:var(--primary);

    font-size:18px;

}

.certificate-right img{

    border-radius:28px;

    box-shadow:var(--shadow-large);

}

/* =====================================================
   DOWNLOAD CENTER
===================================================== */

.resources-section{

    padding:120px 0;

    background:#ffffff;

}

.resources-grid{

    display:grid;

    grid-template-columns:repeat(4,1fr);

    gap:28px;

}

.resource-card{

    background:#ffffff;

    border:1px solid var(--border);

    border-radius:22px;

    padding:36px 28px;

    text-align:center;

    transition:var(--transition);

    box-shadow:var(--shadow-small);

}

.resource-card:hover{

    transform:translateY(-10px);

    box-shadow:var(--shadow);

}

.resource-card i{

    width:72px;

    height:72px;

    margin:auto;

    margin-bottom:24px;

    border-radius:18px;

    background:#eef5ff;

    color:var(--primary);

    display:flex;

    align-items:center;

    justify-content:center;

    font-size:28px;

}

.resource-card h3{

    font-size:24px;

    margin-bottom:16px;

}

.resource-card p{

    color:var(--gray);

    margin-bottom:26px;

}

.resource-btn{

    display:inline-flex;

    justify-content:center;

    align-items:center;

    width:100%;

    height:52px;

    border-radius:50px;

    background:var(--primary);

    color:#ffffff;

    font-weight:600;

    transition:var(--transition);

}

.resource-btn:hover{

    background:var(--primary-dark);

}/* =====================================================
   GLOBAL MARKET
===================================================== */

.global-section{

    padding:120px 0;

    background:var(--light);

}

.global-grid{

    display:grid;

    grid-template-columns:1fr 1fr;

    gap:80px;

    align-items:center;

}

.global-content h2{

    font-size:48px;

    line-height:1.15;

    margin:20px 0 30px;

}

.global-content p{

    color:var(--gray);

    margin-bottom:35px;

}

.market-list{

    display:flex;

    flex-wrap:wrap;

    gap:14px;

}

.market-list span{

    padding:12px 22px;

    background:#ffffff;

    border-radius:50px;

    border:1px solid var(--border);

    font-size:14px;

    font-weight:600;

    transition:var(--transition);

}

.market-list span:hover{

    background:var(--primary);

    color:#ffffff;

    border-color:var(--primary);

}

.global-image img{

    border-radius:28px;

    box-shadow:var(--shadow-large);

}

/* =====================================================
   CTA
===================================================== */

.cta-section{

    padding:120px 0;

    background:#ffffff;

}

.cta-box{

    background:linear-gradient(135deg,#0057ff,#003bb3);

    border-radius:32px;

    padding:90px 70px;

    text-align:center;

    color:#ffffff;

}

.cta-box h2{

    font-size:54px;

    line-height:1.1;

    margin-bottom:24px;

}

.cta-box p{

    max-width:760px;

    margin:0 auto 40px;

    opacity:.9;

    font-size:18px;

}

.cta-box .primary-btn{

    background:#ffffff;

    color:var(--primary);

}

.cta-box .primary-btn:hover{

    background:#eef5ff;

}

/* =====================================================
   CONTACT
===================================================== */

.contact-section{

    padding:120px 0;

    background:#ffffff;

}

.contact-grid{

    display:grid;

    grid-template-columns:1fr 1fr;

    gap:80px;

    align-items:center;

}

.contact-left h2{

    font-size:48px;

    line-height:1.15;

    margin:20px 0 28px;

}

.contact-left p{

    color:var(--gray);

    margin-bottom:35px;

}

.contact-information{

    display:grid;

    gap:18px;

}

.contact-item{

    display:flex;

    align-items:center;

    gap:20px;

    padding:22px;

    border-radius:18px;

    background:#f8fbff;

}

.contact-item i{

    width:54px;

    height:54px;

    border-radius:14px;

    background:var(--primary);

    color:#ffffff;

    display:flex;

    align-items:center;

    justify-content:center;

    font-size:20px;

}

.contact-item strong{

    display:block;

    margin-bottom:6px;

}

.contact-right img{

    border-radius:28px;

    box-shadow:var(--shadow-large);

}

/* =====================================================
   FOOTER
===================================================== */

.footer{

    background:#0f172a;

    color:#ffffff;

    padding:90px 0 30px;

}

.footer-grid{

    display:grid;

    grid-template-columns:2fr 1fr 1fr 1fr;

    gap:50px;

    margin-bottom:50px;

}

.footer-about img{

    width:180px;

    margin-bottom:24px;

}

.footer-about p{

    color:#cbd5e1;

}

.footer-column h4{

    margin-bottom:20px;

    font-size:18px;

}

.footer-column ul li{

    margin-bottom:14px;

}

.footer-column a{

    color:#cbd5e1;

    transition:.3s;

}

.footer-column a:hover{

    color:#ffffff;

}

.social-links{

    display:flex;

    gap:16px;

}

.social-links a{

    width:44px;

    height:44px;

    border-radius:50%;

    background:#1e293b;

    display:flex;

    align-items:center;

    justify-content:center;

    transition:.3s;

}

.social-links a:hover{

    background:var(--primary);

}

.footer-bottom{

    border-top:1px solid rgba(255,255,255,.08);

    padding-top:25px;

    text-align:center;

    color:#94a3b8;

}

/* =====================================================
   BACK TO TOP
===================================================== */

#backToTop{

    position:fixed;

    right:30px;

    bottom:30px;

    width:54px;

    height:54px;

    border:none;

    border-radius:50%;

    background:var(--primary);

    color:#ffffff;

    cursor:pointer;

    display:none;

    align-items:center;

    justify-content:center;

    box-shadow:var(--shadow);

    transition:.35s;

    z-index:999;

}

#backToTop:hover{

    transform:translateY(-5px);

    background:var(--primary-dark);

}

/* =====================================================
   SCROLL ANIMATION
===================================================== */

.product-card,
.application-card,
.why-card,
.resource-card,
.stat-item{

    opacity:0;

    transform:translateY(40px);

    transition:.8s ease;

}

.product-card.show,
.application-card.show,
.why-card.show,
.resource-card.show,
.stat-item.show{

    opacity:1;

    transform:translateY(0);

}
